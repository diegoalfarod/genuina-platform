# Copia este archivo a .env y rellena los valores.
# Neon: DATABASE_URL con pooling (-pooler + &pgbouncer=true), DATABASE_URL_UNPOOLED directa.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
AUTH_SECRET="genera-un-secreto-largo-y-aleatorio"

# Módulo de Leads: conexión de SOLO LECTURA a la base de Genuina AI (rol Postgres
# genuina_dashboard_ro — solo puede ejecutar funciones SECURITY DEFINER, no lee ni
# escribe tablas directo). Ver README.md → "Conectar el módulo de Leads".
GENUINA_AI_DATABASE_URL="postgresql://genuina_dashboard_ro:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# No incluidas todavía — se añaden cuando el dashboard sume su primer agente con IA real:
# ANTHROPIC_API_KEY=""
# CRON_SECRET="genera-otro-secreto-largo-y-aleatorio"
