# Copia este archivo a .env y rellena los valores.
# Neon: DATABASE_URL con pooling (-pooler + &pgbouncer=true), DATABASE_URL_UNPOOLED directa.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DATABASE_URL_UNPOOLED="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"
AUTH_SECRET="genera-un-secreto-largo-y-aleatorio"

# No incluidas todavía — se añaden cuando este cliente sume su primer agente con IA real:
# ANTHROPIC_API_KEY=""
# CRON_SECRET="genera-otro-secreto-largo-y-aleatorio"
